{
  "AuthServer": {
    "Authority": "https://localhost:44368",
    "RequireHttpsMetadata": false,
    "Audience": "VNext"
  },
  "AgileConfig": {
    "appId": "VNext_Gateway",
    "secret": "VNext_Gateway",
    "nodes": "http://localhost:5000",
    "name": "CheMa.VNext.Gateway",
    "env": "DEV"
  },
  "Gateway": {
    "Tenancy": {
      "HeaderName": "__tenant",
      "TenantIdHeaderName": "X-Tenant-Id",
      "TenantSourceHeaderName": "X-Tenant-Source",
      "TenantSegmentName": "tenants"
    },
    "Canary": {
      "HeaderName": "X-Gateway-Canary",
      "TenantWhitelist": []
    },
    "Swagger": {
      "RoutePrefix": "swagger",
      "Documents": [
        {
          "Name": "httpapi-v1",
          "DisplayName": "HttpApi Host",
          "JsonUrl": "/swagger/docs/httpapi-v1"
        }
      ],
      "Downstreams": {
        "httpapi-v1": {
          "DisplayName": "HttpApi Host",
          "JsonUrl": "https://localhost:44368/swagger/v1/swagger.json"
        }
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "public-httpapi-canary": {
        "ClusterId": "httpapi-canary",
        "Order": -1,
        "AuthorizationPolicy": "gateway-authenticated",
        "Match": {
          "Path": "/api/{**catch-all}",
          "Headers": [
            {
              "Name": "X-Gateway-Canary",
              "Values": [
                "True"
              ],
              "Mode": "ExactHeader"
            }
          ]
        },
        "Metadata": {
          "RouteGroup": "public"
        }
      },
      "public-httpapi": {
        "ClusterId": "httpapi-stable",
        "Order": 0,
        "AuthorizationPolicy": "gateway-authenticated",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Metadata": {
          "RouteGroup": "public"
        }
      },
      "internal-httpapi-swagger": {
        "ClusterId": "httpapi-stable",
        "Order": -10,
        "Match": {
          "Path": "/downstream/httpapi/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/swagger/{**catch-all}"
          }
        ],
        "Metadata": {
          "RouteGroup": "internal"
        }
      }
    },
    "Clusters": {
      "httpapi-stable": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:44368/"
          }
        }
      },
      "httpapi-canary": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:44368/"
          }
        }
      }
    }
  }
}
