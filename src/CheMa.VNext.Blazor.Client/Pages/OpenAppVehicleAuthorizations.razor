@page "/open-platform/vehicle-authorizations"
@attribute [Authorize(PolicyName)]
@using CheMa.VNext.OpenPlatform.AppServices
@using CheMa.VNext.Vehicles.AppServices
@inherits VNextComponentBase
@inject IOpenAppAppService OpenAppAppService
@inject IVehicleAppService VehicleAppService
@inject IOpenAppVehicleAuthorizationAppService OpenAppVehicleAuthorizationAppService
@inject IUiMessageService UiMessageService

<PageTitle>@L["OpenPlatform:VehicleAuthorizations"]</PageTitle>

<AuthorizeView Policy="@PolicyName">
    <Authorized Context="authContext">
        <div class="container-fluid py-4">
            <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
                <div>
                    <div class="text-uppercase text-muted small mb-2">@L["Menu:OpenPlatform"]</div>
                    <h2 class="mb-1">@L["OpenPlatform:VehicleAuthorizations"]</h2>
                    <p class="text-muted mb-0">@L["OpenPlatform:ManageVehicleAuthorizations"]</p>
                </div>
                <AuthorizeView Policy="@ManagePolicyName">
                    <Authorized Context="manageAuth">
                        <button type="button" class="btn btn-primary" @onclick="OpenAuthorizeModalAsync">@L["OpenPlatform:AuthorizeVehicle"]</button>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="row g-3 align-items-end mb-4">
                <div class="col-12 col-lg-6">
                    <label class="form-label">@L["OpenPlatform:App"]</label>
                    <input class="form-control" value="@(CurrentOpenApp?.Name ?? string.Empty)" placeholder="@L["OpenPlatform:SelectAppFromAppList"]" disabled />
                </div>
                <div class="col-12 col-lg-4">
                    <label class="form-label">@L["OpenPlatform:Vehicle"]</label>
                    <select class="form-select" value="@SelectedVehicleIdText" @onchange="OnVehicleChanged">
                        <option value="">@L["OpenPlatform:All"]</option>
                        @foreach (var vehicle in Vehicles)
                        {
                            <option value="@vehicle.Id">@vehicle.Vin</option>
                        }
                    </select>
                </div>
                <div class="col-12 col-lg-2 d-flex gap-2">
                    <button type="button" class="btn btn-primary" @onclick="LoadAsync">@L["OpenPlatform:Search"]</button>
                </div>
            </div>

            @if (!OpenAppId.HasValue)
            {
                <div class="alert alert-warning mb-0">@L["OpenPlatform:SelectAppFromAppList"]</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>@L["OpenPlatform:App"]</th>
                                <th>@L["OpenPlatform:VehicleVin"]</th>
                                <th>@L["OpenPlatform:DeviceVin"]</th>
                                <th>@L["OpenPlatform:VendorDeviceId"]</th>
                                <th>@L["OpenPlatform:AuthorizationPeriod"]</th>
                                <th>@L["OpenPlatform:AuthorizationStatus"]</th>
                                <th>@L["OpenPlatform:Actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (FilteredItems.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">-</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in FilteredItems)
                                {
                                    <tr>
                                        <td>@GetOpenAppName(item.OpenAppId)</td>
                                        <td><code>@item.VehicleVin</code></td>
                                        <td><code>@item.DeviceVin</code></td>
                                        <td>@item.VendorDeviceId</td>
                                        <td>
                                            <div class="small fw-semibold">@FormatDateTime(item.AuthorizationStartTime)</div>
                                            <div class="text-muted small">@FormatDateTime(item.AuthorizationEndTime)</div>
                                        </td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(item)">@GetStatusText(item)</span>
                                        </td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-2">
                                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => OpenDetailModalAsync(item)">@L["OpenPlatform:View"]</button>
                                                <AuthorizeView Policy="@ManagePolicyName">
                                                    <Authorized Context="manageAuth2">
                                                        <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => OpenRenewModalAsync(item)">@L["OpenPlatform:Renew"]</button>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => OpenCancelModalAsync(item)">@L["OpenPlatform:CancelAuthorization"]</button>
                                                    </Authorized>
                                                </AuthorizeView>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (IsAuthorizeModalVisible)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@L["OpenPlatform:AuthorizeVehicle"]</h5>
                            <button type="button" class="btn-close" @onclick="CloseAuthorizeModalAsync"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:App"]</label>
                                    <select class="form-select" value="@AuthorizeModel.OpenAppIdText" @onchange="OnAuthorizeOpenAppChanged" disabled="@OpenAppId.HasValue">
                                        <option value="">@L["OpenPlatform:SelectApp"]</option>
                                        @foreach (var app in OpenApps)
                                        {
                                            <option value="@app.Id">@app.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:Vehicle"]</label>
                                    <select class="form-select" value="@AuthorizeModel.VehicleIdText" @onchange="OnAuthorizeVehicleChanged">
                                        <option value="">@L["OpenPlatform:SelectVehicle"]</option>
                                        @foreach (var vehicle in Vehicles)
                                        {
                                            <option value="@vehicle.Id">@vehicle.Vin</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:BeginTime"]</label>
                                    <input class="form-control" type="datetime-local" value="@ToDateTimeLocalValue(AuthorizeModel.AuthorizationStartTime)" @onchange="OnAuthorizeStartTimeChanged" />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:EndTime"]</label>
                                    <input class="form-control" type="datetime-local" value="@ToDateTimeLocalValue(AuthorizeModel.AuthorizationEndTime)" @onchange="OnAuthorizeEndTimeChanged" />
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" @onclick="CloseAuthorizeModalAsync">@L["OpenPlatform:Cancel"]</button>
                            <button type="button" class="btn btn-primary" @onclick="AuthorizeAsync">@L["OpenPlatform:Save"]</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (IsRenewModalVisible)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div>
                                <h5 class="modal-title mb-1">@L["OpenPlatform:Renew"]</h5>
                                <div class="small text-muted">@RenewingItemSummary</div>
                            </div>
                            <button type="button" class="btn-close" @onclick="CloseRenewModalAsync"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">@L["OpenPlatform:BeginTime"]</label>
                                    <input class="form-control" type="datetime-local" value="@ToDateTimeLocalValue(RenewModel.AuthorizationStartTime)" @onchange="OnRenewStartTimeChanged" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">@L["OpenPlatform:EndTime"]</label>
                                    <input class="form-control" type="datetime-local" value="@ToDateTimeLocalValue(RenewModel.AuthorizationEndTime)" @onchange="OnRenewEndTimeChanged" />
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" @onclick="CloseRenewModalAsync">@L["OpenPlatform:Cancel"]</button>
                            <button type="button" class="btn btn-primary" @onclick="RenewAsync">@L["OpenPlatform:Save"]</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (IsCancelModalVisible)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <div>
                                <h5 class="modal-title mb-1">@L["OpenPlatform:CancelAuthorization"]</h5>
                                <div class="small text-muted">@CancellingItemSummary</div>
                            </div>
                            <button type="button" class="btn-close" @onclick="CloseCancelModalAsync"></button>
                        </div>
                        <div class="modal-body">
                            <label class="form-label">@L["OpenPlatform:CancelTime"]</label>
                            <input class="form-control" type="datetime-local" value="@ToDateTimeLocalValue(CancelModel.CancelTime)" @onchange="OnCancelTimeChanged" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" @onclick="CloseCancelModalAsync">@L["OpenPlatform:Cancel"]</button>
                            <button type="button" class="btn btn-danger" @onclick="CancelAsync">@L["OpenPlatform:ConfirmCancelAuthorization"]</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (IsDetailModalVisible && DetailItem != null)
        {
            <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@L["OpenPlatform:AuthorizationDetail"]</h5>
                            <button type="button" class="btn-close" @onclick="CloseDetailModalAsync"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:App"]</label>
                                    <input class="form-control" value="@GetOpenAppName(DetailItem.OpenAppId)" disabled />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:VehicleVin"]</label>
                                    <input class="form-control" value="@DetailItem.VehicleVin" disabled />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:DeviceVin"]</label>
                                    <input class="form-control" value="@DetailItem.DeviceVin" disabled />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:VendorDeviceId"]</label>
                                    <input class="form-control" value="@DetailItem.VendorDeviceId" disabled />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:BeginTime"]</label>
                                    <input class="form-control" value="@FormatDateTime(DetailItem.AuthorizationStartTime)" disabled />
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label">@L["OpenPlatform:EndTime"]</label>
                                    <input class="form-control" value="@FormatDateTime(DetailItem.AuthorizationEndTime)" disabled />
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-primary" @onclick="CloseDetailModalAsync">@L["OpenPlatform:Close"]</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>
