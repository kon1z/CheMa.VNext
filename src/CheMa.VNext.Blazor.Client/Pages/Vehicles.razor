@page "/vehicles"
@inherits VNextComponentBase
@inject IVehicleAppService VehicleAppService
@inject IUiMessageService UiMessageService

<PageTitle>车辆管理</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <div class="text-uppercase text-muted small mb-2">Vehicle</div>
            <h2 class="mb-1">车辆管理</h2>
            <p class="text-muted mb-0">管理车辆档案与车机绑定信息。</p>
        </div>
        <button type="button" class="btn btn-primary" @onclick="OpenCreateModalAsync">新建车辆</button>
    </div>

    <div class="row g-3 align-items-end mb-4">
        <div class="col-12 col-lg-6">
            <label class="form-label">车架号 / 车牌号</label>
            <input class="form-control" value="@Filter" @oninput="OnFilterInput" placeholder="输入车架号或车牌号" />
        </div>
        <div class="col-12 col-lg-3 d-flex gap-2">
            <button type="button" class="btn btn-primary" @onclick="LoadAsync">查询</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>车架号</th>
                    <th>车牌号</th>
                    <th>车机类型</th>
                    <th>绑定状态</th>
                    <th>绑定时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @if (VehicleItems.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">-</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in VehicleItems)
                    {
                        <tr>
                            <td><code>@item.Vin</code></td>
                            <td>@(string.IsNullOrWhiteSpace(item.PlateNumber) ? "-" : item.PlateNumber)</td>
                            <td>@GetDeviceTypeText(item.DeviceType)</td>
                            <td>
                                <span class="badge @(item.BindingStatus == VehicleBindingStatus.Bound ? "text-bg-success" : "text-bg-secondary")">
                                    @GetBindingStatusText(item.BindingStatus)
                                </span>
                            </td>
                            <td>@FormatDateTime(item.BindingTime)</td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditModalAsync(item)">编辑</button>
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item)">删除</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (IsEditModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(EditingId.HasValue ? "编辑车辆" : "新建车辆")</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModalAsync"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label">车架号</label>
                            <input class="form-control" value="@EditModel.Vin" @oninput="OnVinInput" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label">车牌号</label>
                            <input class="form-control" value="@EditModel.PlateNumber" @oninput="OnPlateNumberInput" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">车机供应商类型</label>
                            <select class="form-select" value="@((int)EditModel.DeviceType)" @onchange="OnDeviceTypeChanged">
                                @foreach (var option in DeviceTypeOptions)
                                {
                                    <option value="@((int)option)">@GetDeviceTypeText(option)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">绑定状态</label>
                            <input class="form-control" value="@GetBindingStatusText(EditModel.BindingStatus)" disabled />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">绑定时间</label>
                            <input class="form-control" type="text" value="@FormatDateTime(EditModel.BindingTime)" disabled />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="CloseEditModalAsync">取消</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveAsync">保存</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private static readonly VehicleDeviceType[] DeviceTypeOptions =
    [
        VehicleDeviceType.MaiHong,
        VehicleDeviceType.Other
    ];

    private List<VehicleDto> VehicleItems { get; set; } = [];
    private string? Filter { get; set; }
    private bool IsEditModalVisible { get; set; }
    private Guid? EditingId { get; set; }
    private VehicleEditModel EditModel { get; set; } = VehicleEditModel.CreateDefault();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var result = await VehicleAppService.GetListAsync(new GetVehicleListInput
        {
            Filter = Filter,
            MaxResultCount = 100,
            SkipCount = 0,
            Sorting = nameof(VehicleDto.CreationTime) + " desc"
        });

        VehicleItems = result.Items.ToList();
    }

    private Task OpenCreateModalAsync()
    {
        EditingId = null;
        EditModel = VehicleEditModel.CreateDefault();
        IsEditModalVisible = true;
        return Task.CompletedTask;
    }

    private Task OpenEditModalAsync(VehicleDto item)
    {
        EditingId = item.Id;
        EditModel = VehicleEditModel.FromDto(item);
        IsEditModalVisible = true;
        return Task.CompletedTask;
    }

    private Task CloseEditModalAsync()
    {
        IsEditModalVisible = false;
        EditingId = null;
        EditModel = VehicleEditModel.CreateDefault();
        return Task.CompletedTask;
    }

    private async Task SaveAsync()
    {
        try
        {
            if (EditModel.BindingStatus != VehicleBindingStatus.Bound)
            {
                EditModel.BindingTime = null;
            }

            if (EditingId.HasValue)
            {
                await VehicleAppService.UpdateAsync(EditingId.Value, EditModel.ToUpdateDto());
            }
            else
            {
                await VehicleAppService.CreateAsync(EditModel.ToCreateDto());
            }

            await UiMessageService.Success("保存成功");
            await CloseEditModalAsync();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            await UiMessageService.Error(ex.Message);
        }
    }

    private async Task DeleteAsync(VehicleDto item)
    {
        var confirmed = await UiMessageService.Confirm($"确认删除车辆 {item.Vin} 吗？");
        if (!confirmed)
        {
            return;
        }

        try
        {
            await VehicleAppService.DeleteAsync(item.Id);
            await UiMessageService.Success("删除成功");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            await UiMessageService.Error(ex.Message);
        }
    }

    private void OnFilterInput(ChangeEventArgs args)
    {
        Filter = args.Value?.ToString();
    }

    private void OnVinInput(ChangeEventArgs args)
    {
        EditModel.Vin = args.Value?.ToString() ?? string.Empty;
    }

    private void OnPlateNumberInput(ChangeEventArgs args)
    {
        EditModel.PlateNumber = args.Value?.ToString();
    }

    private void OnDeviceTypeChanged(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var value) && Enum.IsDefined(typeof(VehicleDeviceType), value))
        {
            EditModel.DeviceType = (VehicleDeviceType)value;
        }
    }

    private static string GetDeviceTypeText(VehicleDeviceType deviceType)
    {
        return deviceType switch
        {
            VehicleDeviceType.MaiHong => "迈鸿车机",
            VehicleDeviceType.Other => "其他供应商车机",
            _ => "未知"
        };
    }

    private static string GetBindingStatusText(VehicleBindingStatus bindingStatus)
    {
        return bindingStatus switch
        {
            VehicleBindingStatus.Bound => "已绑定",
            _ => "未绑定"
        };
    }

    private static string FormatDateTime(DateTime? value)
    {
        return value?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-";
    }

    private sealed class VehicleEditModel
    {
        public string Vin { get; set; } = string.Empty;

        public string? PlateNumber { get; set; }

        public VehicleDeviceType DeviceType { get; set; }

        public VehicleBindingStatus BindingStatus { get; set; }

        public DateTime? BindingTime { get; set; }

        public static VehicleEditModel CreateDefault()
        {
            return new VehicleEditModel
            {
                DeviceType = VehicleDeviceType.MaiHong,
                BindingStatus = VehicleBindingStatus.Unbound,
                BindingTime = null
            };
        }

        public static VehicleEditModel FromDto(VehicleDto dto)
        {
            return new VehicleEditModel
            {
                Vin = dto.Vin,
                PlateNumber = dto.PlateNumber,
                DeviceType = dto.DeviceType,
                BindingStatus = dto.BindingStatus,
                BindingTime = dto.BindingTime
            };
        }

        public CreateVehicleDto ToCreateDto()
        {
            return new CreateVehicleDto
            {
                Vin = Vin,
                PlateNumber = PlateNumber,
                DeviceType = DeviceType,
                BindingStatus = BindingStatus,
                BindingTime = BindingTime
            };
        }

        public UpdateVehicleDto ToUpdateDto()
        {
            return new UpdateVehicleDto
            {
                Vin = Vin,
                PlateNumber = PlateNumber,
                DeviceType = DeviceType,
                BindingStatus = BindingStatus,
                BindingTime = BindingTime
            };
        }
    }
}
