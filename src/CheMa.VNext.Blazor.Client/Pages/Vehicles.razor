@page "/vehicles"
@using CheMa.VNext.VehicleDevices.AppServices
@using CheMa.VNext.VehicleDevices.Dtos
@using CheMa.VNext.VehicleDevices.Inputs
@using CheMa.VNext.Vehicles.AppServices
@using CheMa.VNext.Vehicles.Dtos
@using CheMa.VNext.Vehicles.Enums
@using CheMa.VNext.Vehicles.Inputs
@inherits VNextComponentBase
@inject IVehicleAppService VehicleAppService
@inject IVehicleDeviceAppService VehicleDeviceAppService
@inject IUiMessageService UiMessageService

<PageTitle>车辆管理</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
        <div>
            <div class="text-uppercase text-muted small mb-2">Vehicle</div>
            <h2 class="mb-1">车辆管理</h2>
            <p class="text-muted mb-0">管理车辆档案与车机绑定信息。</p>
        </div>
        <button type="button" class="btn btn-primary" @onclick="OpenCreateModalAsync">新建车辆</button>
    </div>

    <div class="row g-3 align-items-end mb-4">
        <div class="col-12 col-lg-6">
            <label class="form-label">车架号 / 车牌号</label>
            <input class="form-control" value="@Filter" @oninput="OnFilterInput" placeholder="输入车架号或车牌号" />
        </div>
        <div class="col-12 col-lg-3 d-flex gap-2">
            <button type="button" class="btn btn-primary" @onclick="LoadAsync">查询</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>车架号</th>
                    <th>车牌号</th>
                    <th>发动机编号</th>
                    <th>车机类型</th>
                    <th>绑定状态</th>
                    <th>绑定时间</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @if (VehicleItems.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">-</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in VehicleItems)
                    {
                        <tr>
                            <td><code>@item.Vin</code></td>
                            <td>@(string.IsNullOrWhiteSpace(item.PlateNumber) ? "-" : item.PlateNumber)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.EngineNumber) ? "-" : item.EngineNumber)</td>
                            <td>@GetVendorTypeText(item.VendorType)</td>
                            <td>
                                <span class="badge @(item.BindingStatus == VehicleBindingStatus.Bound ? "text-bg-success" : "text-bg-secondary")">
                                    @GetBindingStatusText(item.BindingStatus)
                                </span>
                            </td>
                            <td>
                                <div class="small fw-semibold">@FormatDateTime(item.BindingTime)</div>
                                <div class="text-muted small">@GetBindingDeviceSummary(item)</div>
                            </td>
                            <td>
                                <div class="d-flex flex-wrap gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditModalAsync(item)">编辑</button>
                                    @if (item.BindingStatus == VehicleBindingStatus.Bound)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-warning" @onclick="() => UnbindAsync(item)">解绑车机</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-primary" @onclick="() => OpenBindModalAsync(item)">绑定车机</button>
                                    }
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item)">删除</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (IsEditModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(EditingId.HasValue ? "编辑车辆" : "新建车辆")</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModalAsync"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label class="form-label">车架号</label>
                            <input class="form-control" value="@EditModel.Vin" @oninput="OnVinInput" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">车牌号</label>
                            <input class="form-control" value="@EditModel.PlateNumber" @oninput="OnPlateNumberInput" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">发动机编号</label>
                            <input class="form-control" value="@EditModel.EngineNumber" @oninput="OnEngineNumberInput" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">绑定状态</label>
                            <input class="form-control" value="@GetBindingStatusText(EditModel.BindingStatus)" disabled />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">车机类型</label>
                            <input class="form-control" type="text" value="@GetVendorTypeText(EditModel.VendorType)" disabled />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">绑定时间</label>
                            <input class="form-control" type="text" value="@FormatDateTime(EditModel.BindingTime)" disabled />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="CloseEditModalAsync">取消</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveAsync">保存</button>
                </div>
            </div>
        </div>
    </div>
}

@if (IsBindModalVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-1">绑定车机</h5>
                        <div class="small text-muted">@BindingVehicleVin</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseBindModalAsync"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">车机类型</label>
                            <select class="form-select" value="@((int)BindModel.VendorType)" @onchange="OnBindVendorTypeChanged">
                                @foreach (var option in VendorTypeOptions)
                                {
                                    <option value="@((int)option)">@GetVendorTypeText(option)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">车辆品牌</label>
                            <input class="form-control form-control-sm mb-2" value="@BrandFilter" @oninput="OnBrandFilterInput" placeholder="输入品牌名称或 ID 过滤" disabled="@(IsLoadingBrands || BindModel.VendorType != VehicleDeviceVendorType.MaiHong)" />
                            <select class="form-select" value="@BindModel.BrandId" @onchange="OnBindBrandChanged" disabled="@(IsLoadingBrands || BindModel.VendorType != VehicleDeviceVendorType.MaiHong)">
                                <option value="">请选择车辆品牌</option>
                                @foreach (var option in FilteredBrandOptions)
                                {
                                    <option value="@option.Id">@GetOptionText(option.Name, option.Id)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">车系</label>
                            <input class="form-control form-control-sm mb-2" value="@StyleFilter" @oninput="OnStyleFilterInput" placeholder="输入车系名称或 ID 过滤" disabled="@(IsLoadingStyles || string.IsNullOrWhiteSpace(BindModel.BrandId) || BindModel.VendorType != VehicleDeviceVendorType.MaiHong)" />
                            <select class="form-select" value="@BindModel.StyleId" @onchange="OnBindStyleChanged" disabled="@(IsLoadingStyles || string.IsNullOrWhiteSpace(BindModel.BrandId) || BindModel.VendorType != VehicleDeviceVendorType.MaiHong)">
                                <option value="">请选择车系</option>
                                @foreach (var option in FilteredStyleOptions)
                                {
                                    <option value="@option.Id">@GetOptionText(option.Name, option.Id)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">车型</label>
                            <input class="form-control form-control-sm mb-2" value="@ModelFilter" @oninput="OnModelFilterInput" placeholder="输入车型名称或 ID 过滤" disabled="@(IsLoadingModels || string.IsNullOrWhiteSpace(BindModel.StyleId) || BindModel.VendorType != VehicleDeviceVendorType.MaiHong)" />
                            <select class="form-select" value="@BindModel.ModelId" @onchange="OnBindModelChanged" disabled="@(IsLoadingModels || string.IsNullOrWhiteSpace(BindModel.StyleId) || BindModel.VendorType != VehicleDeviceVendorType.MaiHong)">
                                <option value="">请选择车型</option>
                                @foreach (var option in FilteredModelOptions)
                                {
                                    <option value="@option.Id">@GetOptionText(option.Name, option.Id)</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">供应商设备编号</label>
                            <input class="form-control" value="@BindModel.VendorDeviceId" @oninput="OnVendorDeviceIdInput" placeholder="请输入供应商设备编号" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" @onclick="CloseBindModalAsync">取消</button>
                    <button type="button" class="btn btn-primary" @onclick="BindAsync">确认绑定</button>
                </div>
            </div>
        </div>
    </div>
}
